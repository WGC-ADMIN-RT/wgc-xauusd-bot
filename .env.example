# ---- Copy to .env on the server and fill in. NEVER commit the real .env ----

# Database (MySQL on OrangeHost cPanel)
DB_HOST=localhost
DB_NAME=upayztec_wgcxau
DB_USER=upayztec_wgcxau
DB_PASSWORD=
DB_PORT=3306

# Economic calendar + market data (Financial Modeling Prep)
FMP_API_KEY=

# Telegram (WGC Admin bot @WGCAdminBot)
TELEGRAM_BOT_TOKEN=
# Internal/test + Phase 2 approvals:
TELEGRAM_WGC_BOTS_CHAT_ID=
# Member-facing public group:
TELEGRAM_PUBLIC_CHAT_ID=

# Where Phase 1 output goes: "wgc_bots" while testing, "public" once approved
PUBLISH_TARGET=wgc_bots

# Charts: rendered by Chart-IMG (real TradingView charts). Get a key at chart-img.com
# (paid tier needed for studies + drawings + larger sizes; link your TradingView
# Premium in the Chart-IMG dashboard to use your own layouts/indicators).
# Without a key the bot still posts the text intraday plan (chart marked unavailable).
CHART_PROVIDER=chartimg
CHARTIMG_API_KEY=
CHARTIMG_SYMBOL=OANDA:XAUUSD
CHARTIMG_WIDTH=1000
CHARTIMG_HEIGHT=600

# Operational
TIMEZONE=Asia/Singapore
INSTRUMENT=XAUUSD
LOG_LEVEL=INFO
# Intraday analysis timeframe (FMP slug): 5min=M5, 15min=M15, etc.
INTRADAY_TF=5min
