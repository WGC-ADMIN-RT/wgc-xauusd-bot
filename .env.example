# ---- Copy to .env on the server and fill in. NEVER commit the real .env ----

# Database (MySQL on OrangeHost cPanel)
DB_HOST=localhost
DB_NAME=upayztec_wgcxau
DB_USER=upayztec_wgcxau
DB_PASSWORD=
DB_PORT=3306

# Economic calendar + market data (Financial Modeling Prep)
FMP_API_KEY=

# Telegram (WGC Admin bot @WGCAdminBot)
TELEGRAM_BOT_TOKEN=
# Internal/test + Phase 2 approvals:
TELEGRAM_WGC_BOTS_CHAT_ID=
# Member-facing public group:
TELEGRAM_PUBLIC_CHAT_ID=

# Where Phase 1 output goes: "wgc_bots" while testing, "public" once approved
PUBLISH_TARGET=wgc_bots

# Chart provider: "self" (free, self-rendered) or "chartimg" (TradingView via Chart-IMG)
CHART_PROVIDER=self
CHARTIMG_API_KEY=

# Operational
TIMEZONE=Asia/Singapore
INSTRUMENT=XAUUSD
LOG_LEVEL=INFO
