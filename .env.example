# ---- Copy to .env on the server and fill in. NEVER commit the real .env ----

# Database (MySQL on OrangeHost cPanel — create in cPanel → MySQL Databases)
# Typical naming: DB_NAME=YOUR_CPANEL_USER_wgcxau, DB_USER=YOUR_CPANEL_USER_wgcxau
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=3306
# Optional: unix socket path if localhost TCP fails (cPanel → MySQL shows socket path)
DB_SOCKET=

# Economic calendar + market data (Financial Modeling Prep)
FMP_API_KEY=

# Telegram (WGC Admin bot @WGCAdminBot)
TELEGRAM_BOT_TOKEN=
# Internal/test + Phase 2 approvals:
TELEGRAM_WGC_BOTS_CHAT_ID=
# Member-facing public group:
TELEGRAM_PUBLIC_CHAT_ID=

# Where Phase 1 output goes: "wgc_bots" while testing, "public" once approved
PUBLISH_TARGET=wgc_bots

# Charts: rendered by Chart-IMG (real TradingView charts). Get a key at chart-img.com
# (paid tier needed for studies + drawings + larger sizes; link your TradingView
# Premium in the Chart-IMG dashboard to use your own layouts/indicators).
# Without a key the bot still posts the text intraday plan (chart marked unavailable).
CHART_PROVIDER=chartimg
CHARTIMG_API_KEY=
CHARTIMG_SYMBOL=OANDA:XAUUSD
CHARTIMG_WIDTH=800
CHARTIMG_HEIGHT=600
CHARTIMG_MAX_PARAMS=3   # free tier caps studies+drawings at 3; raise on a paid plan

# Render YOUR TradingView account's saved layout (your indicators/drawings/style).
# Layout id = the code in the chart's share URL (e.g. .../chart/OKyFXMzN/ -> OKyFXMzN).
# For a PRIVATE layout or invite-only indicators, add your TradingView session cookies
# (DevTools > Application > Cookies > tradingview.com). SENSITIVE — server .env only.
CHARTIMG_LAYOUT_ID=
CHARTIMG_TV_SESSION_ID=
CHARTIMG_TV_SESSION_SIGN=

# Optional Chart-IMG layout zoom/pan (0 = auto for two Asian sessions). If the chart
# shows only ONE session box, tune manually (typical starting point below).
CHARTIMG_ZOOM_IN=0
CHARTIMG_ZOOM_OUT=0
CHARTIMG_MOVE_LEFT=0
CHARTIMG_MOVE_RIGHT=0
# Manual fallback if auto still shows one box: CHARTIMG_ZOOM_OUT=8 CHARTIMG_MOVE_LEFT=18

# Operational
TIMEZONE=Asia/Singapore
INSTRUMENT=XAUUSD
LOG_LEVEL=INFO
# Intraday analysis timeframe (FMP slug): 5min=M5, 15min=M15, etc.
INTRADAY_TF=5min

# Intraday AI — Claude as a 20-yr XAUUSD trader (M5 execution, H1 bias). When enabled
# AND a key is set, the 2:30 PM plan is AI-generated (key zones as ranges + 4-5 game
# plans) via Anthropic tool-use; otherwise it falls back to the deterministic plan.
# Called over stdlib HTTP (no SDK dependency). Key is SENSITIVE — server .env only.
ANTHROPIC_API_KEY=
INTRADAY_AI_ENABLED=true
INTRADAY_AI_MODEL=claude-opus-4-8
INTRADAY_GAMEPLANS=5
# PDF data-package spread (points). 0 = placeholder when broker feed unavailable.
INTRADAY_SPREAD=0
